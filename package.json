{
  "name": "@skapxd/tree",
  "version": "2.0.0",
  "description": "A directory structure tree generator for CLI",
  "packageManager": "pnpm@11.7.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "tree": "./dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:coverage": "vitest run --coverage -c vitest.unit.config.ts",
    "typecheck": "tsc --noEmit",
    "security:audit": "pnpm audit --audit-level low",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:full": "skapxd-lint . --preset package --yes --format compact",
    "lint:adopt": "skapxd-lint . --preset package --yes --adopt 10 --format compact",
    "lint:changed": "skapxd-lint --changed --preset package --yes --format compact",
    "start": "node dist/cli.cjs"
  },
  "keywords": [
    "directory",
    "tree",
    "cli",
    "ascii",
    "structure"
  ],
  "author": "skapxd",
  "license": "MIT",
  "dependencies": {
    "@skapxd/result": "^2.0.1",
    "commander": "14.0.2",
    "ignore": "7.0.5"
  },
  "devDependencies": {
    "@skapxd/lint-agent": "^1.0.2",
    "@types/commander": "2.12.5",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.6.0",
    "fast-check": "4.8.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.2",
    "vitest": "4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skapxd/tree"
  }
}
